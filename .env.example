# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Search Engines (Optional, DuckDuckGo is used by default - free, no API key required)

# Tavily API (Optional)
# 获取方式：https://tavily.com/
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bing Web Search API (Optional)
# 获取方式：https://www.microsoft.com/en-us/bing/apis/bing-web-search-api
BING_SEARCH_API_KEY=your_bing_search_api_key

# Local Search Service URL (Optional, only for development)
SEARCH_SERVICE_URL=http://localhost:3002
